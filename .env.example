
# Required for the server to start
PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/summit
JWT_SECRET=your-secret-key-change-in-production

# Optional – API base URL for the app
# EXPO_PUBLIC_API_URL=http://localhost:3000

# Optional – Stripe, Mailgun, Twilio, AWS S3, Firebase (server will warn if missing)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# FIREBASE_SERVER_KEY=
# APP_URL=http://localhost:3000
